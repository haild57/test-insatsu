{
    "containerDefinitions": [
        {
            "name": "api",
            "image": "091584011942.dkr.ecr.ap-northeast-1.amazonaws.com/hai-handson-cicd-ecs:latest",
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 80,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "ecs-cicd-LogGroup-oenETmqo76hl",
                    "awslogs-region": "ap-northeast-1",
                    "awslogs-stream-prefix": "ecs"
                }
            }
        }
    ],
    "family": "ecs-cicd-TaskDefinition-88lbmp86xT1I",
    "taskRoleArn": "arn:aws:iam::091584011942:role/ecs-cicd-TaskRole-189893PSROTY5",
    "executionRoleArn": "arn:aws:iam::091584011942:role/ecs-cicd-ExecutionRole-AOWFJPVZA1V8",
    "networkMode": "awsvpc",
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "256",
    "memory": "512",
}